# Application
APP_NAME=Praello AI Knowledge Assistant for Businesses
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000,http://localhost

# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=enterprise_ai
POSTGRES_PASSWORD=enterprise_ai_secret
POSTGRES_DB=enterprise_ai
DATABASE_URL=postgresql+asyncpg://enterprise_ai:enterprise_ai_secret@postgres:5432/enterprise_ai

# Redis
REDIS_URL=redis://redis:6379/0

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=enterprise_knowledge

# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_FALLBACK_MODEL=gpt-4o-mini

# LangSmith (optional)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=praello-ai-knowledge-assistant

# JWT
JWT_SECRET_KEY=change-me-jwt-secret-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Observability
OTEL_ENABLED=false
OTEL_SERVICE_NAME=praello-ai-knowledge-assistant
PROMETHEUS_ENABLED=true

# File uploads
UPLOAD_MAX_SIZE_MB=50
UPLOAD_DIR=/app/uploads
